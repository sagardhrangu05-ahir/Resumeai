# ===========================================
# AI RESUME BUILDER - CONFIGURATION
# ===========================================
# આ file માં તારી API keys નાખ
# .env.local file NEVER share કરવી — secret છે
# ===========================================

# Claude API Key (https://console.anthropic.com/ પરથી લે)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE


# Razorpay Keys (https://dashboard.razorpay.com/ પરથી લે)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET
# તારી Website URL
NEXT_PUBLIC_SITE_URL=https://resumejet.in

# Razorpay Public Key (frontend માટે — same as KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID

# Price in Paise (₹49 = 4900 paise)
NEXT_PUBLIC_PRICE=4900
PRICE_AMOUNT=4900

# Contact Email
CONTACT_EMAIL=sagardhrangu05@gmail.com

# Google Search Console verification code (from GSC → Add property → HTML tag method)
NEXT_PUBLIC_GSC_VERIFICATION=

# Google Analytics 4 Measurement ID (from analytics.google.com → Admin → Data Streams)
NEXT_PUBLIC_GA_ID=

# Gmail SMTP for payment receipt emails
# Use App Password (not main password): Google Account → Security → App passwords
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password_here
